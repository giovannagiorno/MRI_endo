<Window x:Class="EndometriosisClient.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Панель администратора"
        Height="360"
        Width="460"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Панель администратора"
                   FontSize="22"
                   FontWeight="Bold"
                   Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="ФИО врача"/>
            <TextBox x:Name="DoctorFullNameTextBox" Height="28"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,10">
            <TextBlock Text="Логин врача"/>
            <TextBox x:Name="DoctorLoginTextBox" Height="28"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="0,0,0,15">
            <TextBlock Text="Пароль врача"/>
            <PasswordBox x:Name="DoctorPasswordBox" Height="28"/>
        </StackPanel>

        <StackPanel Grid.Row="4" Orientation="Horizontal">
            <Button Content="Добавить врача"
                    Width="150"
                    Height="35"
                    Margin="0,0,10,0"
                    Click="AddDoctorButton_Click"/>

            <Button Content="Открыть все исследования"
                    Width="190"
                    Height="35"
                    Click="OpenStudiesButton_Click"/>
        </StackPanel>

        <TextBlock x:Name="StatusTextBlock"
                   Grid.Row="5"
                   Margin="0,20,0,0"
                   TextWrapping="Wrap"/>
    </Grid>
</Window>