<Window x:Class="EndometriosisClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Сегментация эндометриомы" Height="500" Width="700"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Добавление пациента и МРТ-исследования"
                   FontSize="24"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"/>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="ФИО пациента:"
                       VerticalAlignment="Center"
                       FontSize="14"/>

            <TextBox x:Name="FullNameTextBox"
                     Grid.Column="1"
                     Height="30"
                     FontSize="14"
                     Padding="6"/>
        </Grid>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="200"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Возраст:"
                       VerticalAlignment="Center"
                       FontSize="14"/>

            <TextBox x:Name="AgeTextBox"
                     Grid.Column="1"
                     Height="30"
                     FontSize="14"
                     Padding="6"/>
        </Grid>

        <Grid Grid.Row="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Примечание:"
                       VerticalAlignment="Top"
                       FontSize="14"
                       Margin="0,6,0,0"/>

            <TextBox x:Name="NotesTextBox"
                     Grid.Column="1"
                     Height="80"
                     FontSize="14"
                     Padding="6"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"/>
        </Grid>

        <Grid Grid.Row="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="140"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Файл МРТ:"
                       VerticalAlignment="Center"
                       FontSize="14"/>

            <TextBox x:Name="MriFilePathTextBox"
                     Grid.Column="1"
                     Height="30"
                     FontSize="14"
                     Padding="6"
                     IsReadOnly="True"
                     Margin="0,0,10,0"/>

            <Button Grid.Column="2"
                    Content="Выбрать файл"
                    Height="30"
                    FontSize="14"
                    Click="SelectMriFileButton_Click"/>
        </Grid>

        <StackPanel Grid.Row="10"
            Orientation="Horizontal"
            HorizontalAlignment="Center">
            <Button x:Name="SaveButton"
            Content="Сохранить"
            Width="160"
            Height="40"
            FontSize="14"
            Margin="0,0,10,0"
            Click="SaveButton_Click"/>

            <Button Content="Очистить"
            Width="160"
            Height="40"
            FontSize="14"
            Margin="0,0,10,0"
            Click="ClearButton_Click"/>

            <Button Content="Список исследований"
            Width="180"
            Height="40"
            FontSize="14"
            Click="OpenStudyListButton_Click"/>
        </StackPanel>

        <Border Grid.Row="12"
        BorderBrush="LightGray"
        BorderThickness="1"
        CornerRadius="6"
        Padding="12">
            <StackPanel>

                <TextBlock x:Name="StatusTextBlock"
                   Text="Готово к работе."
                   FontSize="14"
                   TextWrapping="Wrap"/>

                <ProgressBar x:Name="SegmentationProgressBar"
                     Height="18"
                     Minimum="0"
                     Maximum="100"
                     Value="0"
                     Visibility="Collapsed"
                     Margin="0,10,0,0"/>

                <TextBlock x:Name="ProgressPercentTextBlock"
                   Text="0%"
                   FontSize="13"
                   HorizontalAlignment="Center"
                   Visibility="Collapsed"
                   Margin="0,5,0,0"/>

            </StackPanel>
        </Border>
    </Grid>
</Window>