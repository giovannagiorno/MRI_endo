<Window x:Class="EndometriosisClient.ResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Результат сегментации"
        Height="720" Width="1100"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Результат сегментации эндометриомы"
                   FontSize="24"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"/>

        <StackPanel Grid.Row="2">
            <TextBlock x:Name="PatientInfoTextBlock"
                       FontSize="14"
                       Margin="0,0,0,8"/>
            <TextBlock x:Name="StudyInfoTextBlock"
                       FontSize="14"
                       Margin="0,0,0,8"/>
            <TextBlock x:Name="ConclusionTextBlock"
                       FontSize="14"
                       FontWeight="SemiBold"/>
        </StackPanel>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    BorderBrush="Gray"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10">
                <StackPanel>
                    <TextBlock Text="Исходное МРТ-превью"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Margin="0,0,0,10"
                               HorizontalAlignment="Center"/>

                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Auto">
                        <Image x:Name="PreviewImage"
                               Stretch="Uniform"
                               Height="500"/>
                    </ScrollViewer>
                </StackPanel>
            </Border>

            <Border Grid.Column="2"
                    BorderBrush="Gray"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10">
                <StackPanel>
                    <TextBlock Text="Результат сегментации"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Margin="0,0,0,10"
                               HorizontalAlignment="Center"/>

                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Auto">
                        <Image x:Name="ResultImage"
                               Stretch="Uniform"
                               Height="500"/>
                    </ScrollViewer>
                </StackPanel>
            </Border>
        </Grid>

        <StackPanel Grid.Row="6"
            Grid.ColumnSpan="2"
            Orientation="Horizontal"
            HorizontalAlignment="Center"
            Margin="0,20,0,0">

            <Button x:Name="DownloadResultsButton"
            Content="Скачать результаты"
            Width="180"
            Height="35"
            Margin="0,0,15,0"
            Click="DownloadResultsButton_Click"/>

            <Button Content="Закрыть"
            Width="180"
            Height="35"
            Click="CloseButton_Click"/>

        </StackPanel>
    </Grid>
</Window>