<Window x:Class="EndometriosisClient.RegistrationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Регистрация"
        Height="390"
        Width="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Регистрация пользователя"
                   FontSize="22"
                   FontWeight="Bold"
                   Margin="0,0,0,22"/>

        <StackPanel Grid.Row="1" Margin="0,0,0,12">
            <TextBlock Text="ФИО"/>
            <TextBox x:Name="FullNameTextBox"
                     Height="30"
                     VerticalContentAlignment="Center"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,12">
            <TextBlock Text="Логин"/>
            <TextBox x:Name="LoginTextBox"
                     Height="30"
                     VerticalContentAlignment="Center"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="0,0,0,12">
            <TextBlock Text="Пароль"/>
            <PasswordBox x:Name="PasswordBox"
                         Height="30"
                         VerticalContentAlignment="Center"/>
        </StackPanel>

        <StackPanel Grid.Row="4" Margin="0,0,0,18">
            <TextBlock Text="Повторите пароль"/>
            <PasswordBox x:Name="RepeatPasswordBox"
                         Height="30"
                         VerticalContentAlignment="Center"/>
        </StackPanel>

        <Grid Grid.Row="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Content="Зарегистрироваться"
                    Height="38"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Click="RegisterButton_Click"/>

            <Button Grid.Column="2"
                    Content="Отмена"
                    Height="38"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Click="CancelButton_Click"/>
        </Grid>
    </Grid>
</Window>