<Window x:Class="EndometriosisClient.RegistrationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Регистрация"
        Width="520"
        SizeToContent="Height"
        MinHeight="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Border Padding="28">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="18"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="24"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="Регистрация пользователя"
                       FontSize="24"
                       FontWeight="Bold"/>

            <StackPanel Grid.Row="2">
                <TextBlock Text="ФИО" Margin="0,0,0,4"/>
                <TextBox x:Name="FullNameTextBox"
                         Height="34"
                         VerticalContentAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Row="4">
                <TextBlock Text="Логин" Margin="0,0,0,4"/>
                <TextBox x:Name="LoginTextBox"
                         Height="34"
                         VerticalContentAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Row="6">
                <TextBlock Text="Пароль" Margin="0,0,0,4"/>
                <PasswordBox x:Name="PasswordBox"
                             Height="34"
                             VerticalContentAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Row="8">
                <TextBlock Text="Повторите пароль" Margin="0,0,0,4"/>
                <PasswordBox x:Name="RepeatPasswordBox"
                             Height="34"
                             VerticalContentAlignment="Center"/>
            </StackPanel>

            <Grid Grid.Row="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="Зарегистрироваться"
                        Height="40"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Click="RegisterButton_Click"/>

                <Button Grid.Column="2"
                        Content="Отмена"
                        Height="40"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Click="CancelButton_Click"/>
            </Grid>
        </Grid>
    </Border>
</Window>